---
import { getImage } from "astro:assets";
import heroImg from "../assets/hero_bg.png";

const optimisedHero = await getImage({ src: heroImg, format: "webp", width: 1920, quality: 75 });
---

<section class="relative min-h-screen flex items-center pt-24 overflow-hidden">
  <div class="absolute inset-0 z-0">
    <!-- Overlay gradients for depth & legibility -->
    <div
      class="absolute inset-0 bg-gradient-to-r from-[#081423] via-[#081423]/60 to-transparent z-10"
    >
    </div>
    <div
      class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-[#081423] z-10"
    >
    </div>

    <!-- Background video with poster fallback -->
    <video
      autoplay
      loop
      muted
      playsinline
      preload="metadata"
      class="w-full h-full object-cover opacity-40 pointer-events-none"
      poster={optimisedHero.src}
    >
      <source src="/hero_video.mp4" type="video/mp4" />
      <img
        src={optimisedHero.src}
        alt="Fallback Background"
        class="w-full h-full object-cover"
      />
    </video>
  </div>

  <div
    class="relative z-20 max-w-[1440px] mx-auto px-6 md:px-12 w-full grid grid-cols-1 lg:grid-cols-12 gap-12"
  >
    <div class="lg:col-span-10 xl:col-span-8">
      <span
        class="inline-block py-1 px-3 mb-8 border border-primary/30 text-primary font-bold text-[10px] tracking-[0.3em] uppercase bg-primary/5 rounded-sm"
        >The Future of Systems</span
      >
      <h1
        class="font-headline text-5xl md:text-8xl font-bold tracking-tight leading-[1.1] md:leading-[1] mb-10"
      >
        Engineering the <br />
        <span class="text-gradient-gold">Digital Cosmos.</span>
      </h1>
      <p
        class="font-body text-lg md:text-2xl text-on-surface-variant max-w-2xl font-light leading-relaxed mb-12"
      >
        World-class IT consulting, systems management, and AI — purpose-built
        for businesses that demand the extraordinary.
      </p>
      <div class="flex flex-col sm:flex-row gap-6">
        <a
          class="btn-primary-gradient text-on-primary px-12 py-5 font-headline font-bold text-base uppercase tracking-widest rounded-sm flex items-center justify-center gap-4 group"
          href="#contact"
        >
          Initiate Protocol
          <span
            class="material-symbols-outlined group-hover:translate-x-1 transition-transform"
            >arrow_forward</span
          >
        </a>
        <a
          class="border border-white/10 hover:border-primary/50 text-white px-12 py-5 font-headline font-bold text-base uppercase tracking-widest rounded-sm flex items-center justify-center transition-all bg-white/5 backdrop-blur-sm"
          href="#services"
        >
          Explore Orbit
        </a>
      </div>
    </div>
  </div>
</section>
