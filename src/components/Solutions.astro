---
---

<section
  class="py-40 px-6 md:px-12 max-w-[1440px] mx-auto"
  id="solutions"
>
  <div
    class="flex flex-col md:flex-row justify-between items-end mb-24 gap-8"
  >
    <div class="max-w-xl">
      <h2
        class="font-headline text-4xl md:text-6xl font-bold tracking-tight mb-6"
      >
        Core Solutions
      </h2>
      <p class="text-on-surface-variant text-lg leading-relaxed">
        Specialized operational protocols for accelerated enterprise evolution
        and mission success.
      </p>
    </div>
    <div
      class="font-headline text-primary font-bold tracking-widest text-lg uppercase flex items-center gap-4"
    >
      <span class="h-px w-12 bg-primary"></span>
      02 // SOLUTIONS
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
    <!-- Education -->
    <div class="card-glass p-12 group">
      <span
        class="material-symbols-outlined text-primary text-5xl mb-10 group-hover:rotate-12 transition-transform duration-500"
        >school</span
      >
      <h3 class="font-headline text-2xl font-bold mb-6">Education</h3>
      <p
        class="text-on-surface-variant text-base leading-relaxed mb-10 font-light"
      >
        Empowering leadership through intensive AI training and digital AI
        programs designed for the modern frontier.
      </p>
      <div class="pt-8 border-t border-white/5">
        <a
          href="https://www.guidetube.app/"
          class="text-primary font-bold text-[10px] tracking-[0.3em] uppercase hover:underline transition-all"
          target="_blank"
          rel="noopener noreferrer">See Solution</a
        >
      </div>
    </div>

    <!-- Analytics -->
    <div class="card-glass p-12 group">
      <span
        class="material-symbols-outlined text-primary text-5xl mb-10 group-hover:scale-110 transition-transform duration-500"
        >query_stats</span
      >
      <h3 class="font-headline text-2xl font-bold mb-6">Analytics</h3>
      <p
        class="text-on-surface-variant text-base leading-relaxed mb-10 font-light"
      >
        Supportive data-driven insights and predictive modeling to simplify your
        business analytics.
      </p>
      <div class="pt-8 border-t border-white/5">
        <a
          href="#"
          class="text-primary font-bold text-[10px] tracking-[0.3em] uppercase hover:underline transition-all"
          target="_blank"
          rel="noopener noreferrer">Coming Soon</a
        >
      </div>
    </div>

    <!-- IT Consulting -->
    <div class="card-glass p-12 group">
      <span
        class="material-symbols-outlined text-primary text-5xl mb-10 group-hover:translate-y-[-4px] transition-transform duration-500"
        >cloud_sync</span
      >
      <h3 class="font-headline text-2xl font-bold mb-6">IT Consulting</h3>
      <p
        class="text-on-surface-variant text-base leading-relaxed mb-10 font-light"
      >
        Helping businesses and individuals leverage technology to improve
        efficiency and achieve their goals.
      </p>
      <div class="pt-8 border-t border-white/5">
        <a
          href="https://ameeryasin.com"
          class="text-primary font-bold text-[10px] tracking-[0.3em] uppercase hover:underline transition-all"
          target="_blank"
          rel="noopener noreferrer">Learn More</a
        >
      </div>
    </div>
  </div>
</section>
