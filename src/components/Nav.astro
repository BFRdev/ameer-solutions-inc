---
import { Image } from "astro:assets";
import logoImg from "../assets/asi-icon.png";

interface Props {
  variant?: "full" | "privacy";
}

const { variant = "full" } = Astro.props;
---

<nav
  class="fixed top-0 w-full z-50 bg-[#081423]/80 backdrop-blur-xl border-b border-white/5"
>
  <div
    class="flex justify-between items-center px-6 md:px-12 py-5 w-full max-w-[1440px] mx-auto"
  >
    <a href="/" class="flex items-center">
      <Image
        src={logoImg}
        alt="Ameer Solutions Inc."
        class="h-10 w-auto"
        widths={[80, 160]}
        sizes="40px"
        loading="eager"
      />
    </a>

    {
      variant === "full" ? (
        <>
          {/* Desktop links */}
          <div class="hidden md:flex items-center space-x-12">
            <a
              class="text-on-surface-variant/80 font-body text-sm font-medium tracking-wide hover:text-[#f9d056] transition-colors duration-300"
              href="#services"
            >
              Services
            </a>
            <a
              class="text-on-surface-variant/80 font-body text-sm font-medium tracking-wide hover:text-[#f9d056] transition-colors duration-300"
              href="#about"
            >
              Intelligence
            </a>
            <a
              class="text-on-surface-variant/80 font-body text-sm font-medium tracking-wide hover:text-[#f9d056] transition-colors duration-300"
              href="#contact"
            >
              Contact
            </a>
          </div>

          {/* Mobile hamburger */}
          <button
            class="md:hidden text-primary"
            id="menu-toggle"
            aria-label="Open menu"
          >
            <span class="material-symbols-outlined text-3xl">menu</span>
          </button>
        </>
      ) : (
        <a
          href="/"
          class="text-on-surface-variant/80 font-body text-sm font-medium tracking-wide hover:text-[#f9d056] transition-colors duration-300"
        >
          &larr; Back to Home
        </a>
      )
    }
  </div>
</nav>

{/* Fullscreen mobile menu */}
{
  variant === "full" && (
    <div
      id="mobile-menu"
      class="fixed inset-0 z-[60] bg-[#081423]/95 backdrop-blur-2xl flex flex-col items-center justify-center gap-12 hidden"
    >
      <button
        id="menu-close"
        class="absolute top-6 right-6 text-primary"
        aria-label="Close menu"
      >
        <span class="material-symbols-outlined text-3xl">close</span>
      </button>
      <a
        href="#services"
        class="nav-mobile-link font-headline text-3xl font-bold text-on-surface hover:text-primary transition-colors"
      >
        Services
      </a>
      <a
        href="#about"
        class="nav-mobile-link font-headline text-3xl font-bold text-on-surface hover:text-primary transition-colors"
      >
        Intelligence
      </a>
      <a
        href="#contact"
        class="nav-mobile-link font-headline text-3xl font-bold text-on-surface hover:text-primary transition-colors"
      >
        Contact
      </a>
    </div>
  )
}

{
  variant === "full" && (
    <script is:inline>
      {
        const toggle = document.getElementById("menu-toggle");
        const menu = document.getElementById("mobile-menu");
        const close = document.getElementById("menu-close");
        const links = menu.querySelectorAll(".nav-mobile-link");
        toggle.addEventListener("click", () => menu.classList.remove("hidden"));
        close.addEventListener("click", () => menu.classList.add("hidden"));
        links.forEach((l) =>
          l.addEventListener("click", () => menu.classList.add("hidden"))
        );
      }
    </script>
  )
}
